{
  "name": "premium-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:charts": "ng build premium-ui-charts",
    "build:date": "ng build premium-ui-date",
    "build:prerender": "ng build",
    "serve:ssr": "node dist/premium-ui/server/server.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "storybook": "ng run premium-ui:storybook",
    "build-storybook": "ng run premium-ui:build-storybook",
    "lint": "ng lint",
    "serve:ssr:test": "node scripts/serve-prerender.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test tests/e2e/docs/docs-smoke.spec.ts --project=desktop-chromium",
    "test:e2e:routes": "playwright test tests/e2e/docs/docs-routes.spec.ts --project=desktop-chromium",
    "test:a11y": "playwright test tests/e2e/docs/docs-accessibility.spec.ts --project=desktop-chromium",
    "test:visual": "playwright test tests/e2e/visual --project=desktop-chromium",
    "test:lighthouse": "lhci autorun",
    "test:quality": "npm run build && playwright test",
    "test:all": "npm run build && playwright test && npm run test:lighthouse"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/cdk": "^21.2.12",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.14",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.12",
    "@internationalized/date": "^3.12.2",
    "echarts": "^5.6.0",
    "express": "^5.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@axe-core/playwright": "^4.11.3",
    "@compodoc/compodoc": "^1.1.31",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/angular": "^10.4.0",
    "@types/express": "^5.0.6",
    "angular-eslint": "21.4.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.0.0",
    "lighthouse": "^13.3.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.3",
    "storybook": "^10.4.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.0.8"
  }
}
